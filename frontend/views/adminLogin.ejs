<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Admin Login</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
      display: flex;
      height: 100vh;
      justify-content: center;
      align-items: center;
      background-image: url("/components/adminlogin.webp");
      background-repeat: no-repeat;
      background-size: cover;
      background-position: center;
      background-color: #FAFBF8;
    }

    .left-section {
      flex: 1;
      color: black;
      padding: 50px;
    }

    .left-section h1 {
      font-size: 2.5rem;
      margin-bottom: 10px;
    }

    .left-section p {
      font-size: 1rem;
      max-width: 400px;
    }

    .container {
      flex: 1;
      display: flex;
      justify-content: center;
    }

    .login-card {
      background: white;
      padding: 40px;
      border-radius: 10px;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
      text-align: center;
      width: 100%;
      max-width: 400px;
    }

    .login-card h1,
    .login-card h2 {
      margin-bottom: 20px;
    }

    .input-group {
      margin-bottom: 15px;
      text-align: left;
    }

    .input-group label {
      display: block;
      font-size: 14px;
      margin-bottom: 5px;
    }

    .input-group input {
      width: 100%;
      padding: 10px;
      border: 1px solid #ccc;
      border-radius: 5px;
    }

    .login-btn {
      width: 100%;
      padding: 10px;
      background: #388e3c;
      color: white;
      border: none;
      border-radius: 5px;
      font-size: 16px;
      cursor: pointer;
    }

    .login-btn:hover {
      background: #2e7d32;
    }

    .back {
      position: absolute;
      text-decoration: none;
      color: rgb(12, 12, 12);
      font-weight: bold;
      top: 20px;
      left: 20px;
      font-size: 35px;
    }
  </style>
</head>
<body>
  <div class="left-section">
    <h1>Haritha Keralam Mission</h1>
    <p>The mind that welcomes new ideas opens the door to endless possibilities.</p>
  </div>

  <% if (typeof error !== 'undefined') { %>
  <div class="error-popup"><%= error %></div>
<% } %>

<div class="container">
  <form class="login-card" id="adminLoginForm" action="/admin/adminlogin" method="POST">
    <a href="/home" class="back">&lArr;</a>
    <h1>Log In</h1>
    <h2>Admin</h2>

    <div class="input-group">
      <label for="email">Email</label>
      <input type="text" name="email" id="email" placeholder="Enter Admin Email" required />
    </div>

    <div class="input-group">
      <label for="pass">Password</label>
      <input type="password" name="pass" id="pass" placeholder="Enter Password" required />
    </div>

    <button type="submit" class="login-btn" name="submit">Submit</button>
  </form>
</div>

<script>
  class AdminLoginValidator {
    constructor(formId) {
      this.form = document.getElementById(formId);
      this.emailInput = document.getElementById('email');
      this.passInput = document.getElementById('pass');
      this.attachEvents();
    }

    attachEvents() {
      if (!this.form) return;
      this.form.addEventListener('submit', (e) => this.validateForm(e));
    }

    validateForm(e) {
      const email = this.emailInput.value.trim();
      const pass = this.passInput.value.trim();
      let errors = [];

      // ✅ Email validation
      const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
      if (!emailPattern.test(email)) {
        errors.push("Please enter a valid email address.");
      }

      if (errors.length > 0) {
        e.preventDefault();
        alert(errors.join("\n"));
      }
    }
  }

  document.addEventListener('DOMContentLoaded', () => {
    new AdminLoginValidator('adminLoginForm');
  });
</script>

</body>
</html>