    /* About Us Content Styles */
    .about-section {
        max-width: 1200px;
        margin: 60px auto;
        padding: 0 40px;
    }

    .about-content {
        background: white;
        padding: 40px;
        border-radius: 8px;
        box-shadow: 0 4px 12px var(--shadow-color);
    }

    .about-content h2 {
        color: var(--text-dark);
        margin-bottom: 30px;
        font-size: 32px;
        text-align: center;
        font-weight: 600;
    }

    .about-content p {
        color: var(--text-dark);
        line-height: 1.8;
        margin-bottom: 20px;
        font-size: 16px;
    }

    .mission-section {
        display: flex;
        gap: 40px;
        margin: 40px 0;
        align-items: center;
    }

    .mission-text {
        flex: 1;
    }

    .mission-image {
        flex: 1;
        border-radius: 8px;
        overflow: hidden;
        box-shadow: 0 4px 12px var(--shadow-color);
    }

    .mission-image img {
        width: 100%;
        height: auto;
        display: block;
    }

    </style>
