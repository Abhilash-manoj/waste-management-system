        margin: 8px 0;
    }

    .footer-right p {
        font-size: 15px;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.9);
    }

    .footer-left a {
        text-decoration: none;
        color: #81C784;
        font-weight: 500;
        transition: color 0.3s ease;
    }

    .footer-left a:hover {
        color: #A5D6A7;
        text-decoration: underline;
