<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Haritha Kerala Mission</title>
    <style>
        :root {
    --primary-color: #1b5e20;
    --secondary-color: #2e7d32;
    --accent-color: #43a047;
    --text-light: #ffffff;
    --text-dark: #333333;
    --background-light: #f5f5f5;
    --background-dark: #004d40;
    --shadow-color: rgba(0, 0, 0, 0.1);
}

        body {
    margin: 0;
    font-family: 'Segoe UI', Arial, sans-serif;
    background: var(--background-light);
    color: var(--text-dark);
    line-height: 1.6;
}

.container {
    background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url(../components/main.jpeg);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    width: 100%;
    height: 600px;
    margin: 0;
    padding: 0;
    max-width: 100%;
    overflow: hidden;
    position: relative;
}

/* Navigation Bar */
.nav-bar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 15px 40px;
    width: 100%;
    box-sizing: border-box;
    position: relative;
}

.nav-link {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 40px;
    justify-content: center;
    align-items: center;
}

.nav-link a {
    text-decoration: none;
    color:  #032b03;
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    padding: 8px 16px;
    border-radius: 4px;
}

.nav-link a:hover {
    color: white;
    background-color:  #032b03;
}

.dropdown {
    position: relative;
    margin-left: auto;
    z-index: 10;
}

.dropdown button {
    background:  #032b03;
    color: var(--text-light);
    border: none;
    height: 40px;
    width: 100px;
    padding: 8px 16px;
    cursor: pointer;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 500;
    display: block;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 4px var(--shadow-color);
}

.dropdown button {
    position: relative;
    z-index: 1100;
}

.dropdown button:hover {
    background: var(--secondary-color);
    transform: translateY(-1px);
    box-shadow: 0 4px 6px var(--shadow-color);
}

.dropdown-content {
    display: none;
    position: absolute;
    border: none;
    border-radius: 4px;
    top: calc(100% - 2px);
    right: 0;
    background-color: white;
    min-width: 180px;
    box-shadow: 0 4px 12px var(--shadow-color);
    z-index: 2000;
    overflow: hidden;
}

.dropdown-content a {
    display: block;
    padding: 12px 20px;
    text-decoration: none;
    color: var(--text-dark);
    font-size: 14px;
    transition: all 0.2s ease;
}

.dropdown-content a:hover {
    background: var(--background-light);
    color: var(--primary-color);
}

.dropdown:hover .dropdown-content,
.dropdown:focus-within .dropdown-content {
    display: block;
}

/* keyboard accessibility */
.dropdown button:focus + .dropdown-content,
.dropdown:focus-within .dropdown-content {
    display: block;
}

/* keyboard accessibility */
.dropdown button:focus + .dropdown-content,
.dropdown:focus-within .dropdown-content {
    display: block;
}


.hero {
    text-align: center;
    padding: 120px 20px;
    color: var(--text-light);
    max-width: 800px;
    margin: 0 auto;
    position: relative;
}

.hero h1 {
    font-size: 56px;
    margin: 0 0 20px;
    font-weight: 700;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    letter-spacing: -0.5px;
    color: var(--text-light);
}

.hero h2 {
    font-size: 32px;
    margin: 0 0 30px;
    font-weight: 500;
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.2);
    color: rgba(255, 255, 255, 0.9);
}

.hero p {
    font-size: 20px;
    margin: 0;
    line-height: 1.6;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
    color: rgba(255, 255, 255, 0.95);
}

.hero h1, 
.hero h2, 
.hero p {
    line-height: 1.2; 
}




.aboutus {
    width: 80%;
    margin: 50px auto;
    padding: 40px;
    border-radius: 10px;
    text-align: justify;
    background: linear-gradient(rgba(0, 0, 0, 0.7), rgba(0, 0, 0, 0.7));
    overflow: hidden;
    position: relative;
}

.aboutus h1 {
    margin-top: 10px;
    font-size: 32px;
    color: var(--text-light);
    text-align: center;
    margin-bottom: 40px;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
}

.aboutus p {
    font-size: 18px;
    color: rgba(255, 255, 255, 0.95);
    line-height: 1.6;
    margin-bottom: 20px;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
}


.aboutus-img1, .aboutus-img2, .aboutus-img3 {
    display: block;
    width: 100%;
    max-width: 400px;
    height: auto;
    margin: 30px auto;
    border-radius: 10px;
    box-shadow: 0 4px 8px rgba(0, 0, 0, 0.2);
}

.aboutus p {
    display: flow-root;
    margin-bottom: 30px;
}

.aboutus p::after {
    content: "";
    display: table;
    clear: both;
}

@media (min-width: 768px) {
    .aboutus-img1 {
        float: left;
        width: 45%;
        margin: 5px 30px 20px 0;
    }

    .aboutus-img2 {
        float: right;
        width: 45%;
        margin: 5px 0 20px 30px;
    }

    .aboutus-img3 {
        float: left;
        width: 45%;
        margin: 5px 30px 20px 0;
    }
}


footer {
    background-color: #023606;
    padding: 20px;
    font-family: Arial, sans-serif;
}

.footer-container {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
}

.footer-left,
.footer-right {
    width: 50%;
}

.footer-left h3 {
    margin-bottom: 10px;
}

.footer-left img {
    width: 30px;
    height: 30px;
    margin-right: 10px;
    cursor: pointer;
}

.footer-left p,
.footer-right p {
    font-size: 14px;
    line-height: 1.5;
    color: #aaa9a9;
}

.footer-left a {
    text-decoration: none;
    color: #007bff;
}

.footer-left a:hover {
    text-decoration: underline;
}

    /* Footer Styles */
    footer {
