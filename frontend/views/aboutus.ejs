    .footer-left,
    .footer-right {
        width: 50%;
    }

    .footer-left h3 {
        font-size: 20px;
        margin-bottom: 20px;
        color: white;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .footer-left img {
