<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Haritha Kerala Mission</title>
    <style>
        body {
    margin: 0;
    font-family: Arial, sans-serif;
    background: #011502;
    color: white;
}

.container {
    background-image: url(../components/main.jpeg);
    background-repeat: no-repeat;
    background-position: -20px -250px;
    background-size: cover;
    width: 1364px;
    height: 500px;
    margin: 0 auto;
}

/* Navigation Bar */
.nav-bar {
    display: flex;
    justify-content: center; /* Centers the links */
    align-items: center;
    padding: 0px 20px;
    position: relative; /* Allows absolute positioning for the button */
    padding-bottom: 30px;
}
.nav-bar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 10px 20px;
}

.nav-link {
    display: flex;
    gap: 20px;
}

.nav-link a {
    text-decoration: none;
    color: green;
    font-size: 18px;
}

.dropdown {
    position: relative;
    margin-left: 20px;
}

.dropdown button {
    background: black;
    color: white;
    border: solid 2px black;
    margin-right: 10px;
    height: 40px;
    width: 80px;
    padding: 10px;
    cursor: pointer;
    border-radius: 10px;
    font-size: 15px;
}

.dropdown-content {
    display: none;
    position: absolute;
    border: #011502;
    border-radius: 10px;
    top: 41px;
    right: 5px;
    background-color: white;
    min-width: 80px;
    box-shadow: 0px 4px 6px rgba(0, 0, 0, 0.2);
    z-index: 1;
}

.dropdown-content a {
    display: block;
    size: 10px;
    padding: 10px;
    text-decoration: none;
    color: black;
}

.dropdown-content a:hover {
    background: lightgray;
    border: #011502;
    border-radius: 10px;
}

.dropdown:hover .dropdown-content {
    display: block;
}

/* Hero Section */
.hero {
    text-align: left;
    padding: 10px;
    margin-top: 100px;
}

.hero h1 {
    font-size: 48px;
    margin: 5px;
}

.hero h2 {
    font-size: 36px;
    margin: 5px;
}

.hero p {
    font-size: 24px;
    margin: 5px;
}

.hero h1, 
.hero h2, 
.hero p {
    line-height: 1.2; 
}

/* Divider */
.divider {
    width: 100%;
    height: 10px;
    background: #06610c;
    margin: 0px;
}

/* Campaign Section */
.campaigns {
    text-align: center;
}

.campaign-container {
    display: flex;
    gap: 10px;
    justify-content: space-around;
    margin: 20px;
}

.campaign {
    background: #011502;
    border: 5px solid #0a3704;
    border-radius: 10px;
    width: 300px;
    padding: 15px;
    text-align: center;
}

.campaign img {
    width: 100%;
    height: 195px;
}

/* Statistics */
.stats {
    display: flex;
    justify-content: space-around;
    text-align: center;
    background: #0a3704;
    padding: 20px;
    gap: 10px;
    margin: 20px 0;
}

.stat-box {
    background: #023005;
    padding: 10px;
    border-radius: 10px;
    width: 150px;
}
.stat-box h3{
    size:20px;
    text-align: left;
}
.stat-box p{
    size: 10px;
    text-align: left;
}
.stat-box img{
    width: 80px;;
    height: 80px;
}
/* Mission Section */
.mission {
    display: flex;
    align-items: center;
    padding: 20px;
}
.mission-text h2{
    font-size: 40px;
    margin-top: 0px;

}
.mission img {
    width: 50%;
    border-radius: 10px;
}

.mission-text {
    padding-left: 20px;
    text-align: justify;
    font-size: 20px;
}

/* Footer */
footer {
    background-color: #023606;
    padding: 20px;
    font-family: Arial, sans-serif;
}

.footer-container {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
}

.footer-left,
.footer-right {
    width: 50%;
}

.footer-left h3 {
    margin-bottom: 10px;
}

.footer-left img {
    width: 30px;
    height: 30px;
    margin-right: 10px;
    cursor: pointer;
}

.footer-left p,
.footer-right p {
    font-size: 14px;
    line-height: 1.5;
    color: #aaa9a9;
}

.footer-left a {
    text-decoration: none;
    color: #007bff;
}

.footer-left a:hover {
    text-decoration: underline;
}

    </style>
</head>
