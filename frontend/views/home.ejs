<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Haritha Kerala Mission</title>
    <style>
        :root {
            --primary-color: #1b5e20;
            --secondary-color: #2e7d32;
            --accent-color: #43a047;
            --text-light: #ffffff;
            --text-dark: #2c3e50;
            --background-light: #f8f9fa;
            --background-dark: #004d40;
            --shadow-color: rgba(0, 0, 0, 0.08);
            --transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, Arial, sans-serif;
            background: var(--background-light);
            color: var(--text-dark);
            line-height: 1.7;
            -webkit-font-smoothing: antialiased;
        }

        .container {
            background-image: linear-gradient(rgba(0, 0, 0, 0.6), rgba(0, 0, 0, 0.5)), url(../components/main.jpeg);
            background-repeat: no-repeat;
            background-position: center;
            background-size: cover;
            width: 100%;
            height: 650px;
            margin: 0;
            padding: 0;
            max-width: 100%;
            position: relative;
            display: flex;
            flex-direction: column;
        }

        /* Modern Navigation Bar */
        header {
            width: 100%;
            background: rgba(255, 255, 255, 0.95);
            backdrop-filter: blur(10px);
            box-shadow: 0 2px 20px rgba(0,0,0,0.1);
            position: sticky;
            top: 0;
            z-index: 1000;
        }

        .nav-bar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 0 40px;
            max-width: 1400px;
            margin: 0 auto;
            height: 80px;
            box-sizing: border-box;
        }

        .nav-link {
            display: flex;
            gap: 15px;
            align-items: center;
        }

        .nav-link a {
            text-decoration: none;
            color: #2c3e50;
            font-size: 15px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.8px;
            transition: var(--transition);
            padding: 10px 20px;
            border-radius: 6px;
        }

        .nav-link a:hover {
            color: var(--text-light);
            background-color: var(--primary-color);
        }

        /* Enhanced Dropdown Menu */
        .dropdown {
            position: relative;
            z-index: 1010;
        }

        .dropdown button {
            background: var(--primary-color);
            color: var(--text-light);
            border: none;
            height: 44px;
            padding: 0 24px;
            cursor: pointer;
            border-radius: 6px;
            font-size: 14px;
            font-weight: 600;
            transition: var(--transition);
            text-transform: uppercase;
            letter-spacing: 0.8px;
            box-shadow: 0 4px 6px rgba(27, 94, 32, 0.2);
        }

        .dropdown button:hover {
            background: var(--secondary-color);
            transform: translateY(-1px);
            box-shadow: 0 6px 12px rgba(27, 94, 32, 0.3);
        }

        .dropdown-content {
            display: none;
            opacity: 0;
            transform: translateY(10px);
            position: absolute;
            top: calc(100% + 8px);
            right: 0;
            background-color: #ffffff;
            min-width: 220px;
            border-radius: 8px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.15);
            z-index: 2000;
            overflow: hidden;
            border: 1px solid rgba(0,0,0,0.05);
            animation: slideIn 0.25s forwards cubic-bezier(0.4, 0, 0.2, 1);
        }

        @keyframes slideIn {
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .dropdown-content a {
            display: block;
            padding: 14px 24px;
            text-decoration: none;
            color: #34495e;
            font-size: 14px;
            font-weight: 500;
            transition: var(--transition);
            border-bottom: 1px solid #f1f2f6;
        }

        .dropdown-content a:last-child {
            border-bottom: none;
        }

        .dropdown-content a:hover {
            background: #edf7ed;
            color: var(--primary-color);
            padding-left: 28px;
        }

        .dropdown:hover .dropdown-content,
        .dropdown:focus-within .dropdown-content,
        .dropdown button:focus + .dropdown-content {
            display: block;
        }

        /* Hero Section */
        .hero {
            text-align: center;
            padding: 40px 20px;
            color: var(--text-light);
            max-width: 900px;
            margin: auto;
            position: relative;
        }

        .hero h1 {
            font-size: 64px;
            margin: 0;
            font-weight: 800;
            text-shadow: 0 4px 12px rgba(0, 0, 0, 0.5);
            letter-spacing: -1px;
            line-height: 1.1;
        }

        .hero h2 {
            font-size: 28px;
            margin: 20px 0 25px;
            font-weight: 600;
            text-shadow: 0 2px 6px rgba(0, 0, 0, 0.4);
            color: #ffca28;
            text-transform: uppercase;
            letter-spacing: 2px;
        }

        .hero p {
            font-size: 22px;
            margin: 0;
            line-height: 1.6;
            text-shadow: 0 2px 8px rgba(0, 0, 0, 0.5);
            color: rgba(255, 255, 255, 0.95);
            font-weight: 400;
        }

        /* Campaigns Section */
        .campaigns {
            text-align: center;
            padding: 90px 20px;
            background: #ffffff;
        }

        .campaigns h2, .mission-text h2 {
            font-size: 38px;
            font-weight: 700;
            color: #1a301b;
            margin-bottom: 10px;
            position: relative;
        }

        .campaign-container {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
            gap: 30px;
            max-width: 1300px;
            margin: 50px auto 0;
        }

        .campaign {
            background: var(--background-light);
            border-radius: 12px;
            padding: 16px;
            text-align: center;
            box-shadow: 0 4px 15px rgba(0,0,0,0.03);
            transition: var(--transition);
            border: 1px solid rgba(0,0,0,0.02);
        }

        .campaign:hover {
            transform: translateY(-8px);
            box-shadow: 0 12px 30px rgba(0,0,0,0.08);
            background: #ffffff;
        }

        .campaign img {
            width: 100%;
            height: 220px;
            object-fit: cover;
            border-radius: 8px;
            margin-bottom: 15px;
        }

        .campaign p {
            font-size: 16px;
            font-weight: 600;
            color: #2c3e50;
            margin: 10px 0 5px;
        }

        /* Statistics Dashboard Grid */
        .stats {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
            background: linear-gradient(135deg, #0f3d11, #00332c);
            padding: 60px 40px;
            gap: 24px;
            max-width: 100%;
        }

        .stat-box {
            background: rgba(255, 255, 255, 0.06);
            padding: 30px 20px;
            border-radius: 12px;
            backdrop-filter: blur(8px);
            border: 1px solid rgba(255, 255, 255, 0.1);
            transition: var(--transition);
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
        }

        .stat-box:hover {
            transform: translateY(-6px);
            background: rgba(255, 255, 255, 0.12);
            border-color: rgba(255, 255, 255, 0.2);
        }

        .stat-box img {
            width: 64px;
            height: 64px;
            object-fit: contain;
            filter: drop-shadow(0 4px 6px rgba(0,0,0,0.2));
            margin-bottom: 15px;
        }

        .stat-box h3 {
            font-size: 32px;
            font-weight: 700;
            color: #ffca28;
            margin: 0 0 5px;
            letter-spacing: -0.5px;
        }

        .stat-box p {
            font-size: 13px;
            color: rgba(255, 255, 255, 0.85);
            margin: 0;
            line-height: 1.4;
            font-weight: 500;
        }

        /* Mission Section */
        .mission {
            display: flex;
            align-items: center;
            gap: 60px;
            max-width: 1200px;
            margin: 90px auto;
            padding: 0 40px;
        }

        .mission img {
            width: 45%;
            height: 400px;
            object-fit: cover;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.08);
        }

        .mission-text {
            width: 55%;
            text-align: justify;
            font-size: 16px;
            color: #4a5568;
        }

        .mission-text p {
            margin-top: 20px;
        }

        /* Premium Footer Layout */
        footer {
            background: linear-gradient(135deg, #113b13, #00241e);
            color: #e2e8f0;
            padding: 70px 40px 40px;
            box-shadow: 0 -4px 20px rgba(0,0,0,0.05);
        }

        .footer-container {
            display: flex;
            max-width: 1200px;
            margin: 0 auto;
            gap: 80px;
        }

        .footer-left, .footer-right {
            width: 50%;
        }

        .footer-left h3 {
            font-size: 22px;
            margin-bottom: 20px;
            color: var(--text-light);
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 1px;
        }

        .footer-left .social-icons {
            display: flex;
            gap: 12px;
            margin-bottom: 25px;
        }

        .footer-left img {
            width: 38px;
            height: 38px;
            cursor: pointer;
            transition: var(--transition);
            background-color: rgba(255, 255, 255, 0.08);
            padding: 8px;
            border-radius: 50%;
            box-sizing: border-box;
        }

        .footer-left img:hover {
            transform: translateY(-3px);
            background-color: rgba(255, 255, 255, 0.2);
        }

        .footer-left p {
            font-size: 14px;
            line-height: 1.7;
            color: #cbd5e1;
            margin: 10px 0;
        }

        .footer-right p {
            font-size: 14px;
            line-height: 1.8;
            color: #cbd5e1;
            text-align: justify;
        }

        .footer-left a {
            text-decoration: none;
            color: #81C784;
            font-weight: 600;
            transition: color 0.2s ease;
        }

        .footer-left a:hover {
            color: #a5d6a7;
            text-decoration: underline;
        }

        @media (max-width: 900px) {
            .nav-bar { padding: 0 20px; }
            .nav-link { gap: 10px; }
            .mission { flex-direction: column; gap: 30px; }
            .mission img, .mission-text { width: 100%; }
            .footer-container { flex-direction: column; gap: 40px; }
            .footer-left, .footer-right { width: 100%; }
            .hero h1 { font-size: 44px; }
        }
    </style>
</head>
