<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Haritha Kerala Mission</title>
    <style>
        :root {
    --primary-color: #1b5e20;
    --secondary-color: #2e7d32;
    --accent-color: #43a047;
    --text-light: #ffffff;
    --text-dark: #333333;
    --background-light: #f5f5f5;
    --background-dark: #004d40;
    --shadow-color: rgba(0, 0, 0, 0.1);
}

        body {
    margin: 0;
    font-family: 'Segoe UI', Arial, sans-serif;
    background: var(--background-light);
    color: var(--text-dark);
    line-height: 1.6;
}

.container {
    background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url(../components/main.jpeg);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    width: 100%;
    height: 600px;
    margin: 0;
    padding: 0;
    max-width: 100%;
    overflow: hidden;
    position: relative;
}

/* Navigation Bar */
.nav-bar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 15px 40px;
    width: 100%;
    box-sizing: border-box;
    position: relative;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 2px 4px var(--shadow-color);
}

.nav-link {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 40px;
    justify-content: center;
    align-items: center;
}

.nav-link a {
    text-decoration: none;
    color: var(--primary-color);
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    padding: 8px 16px;
    border-radius: 4px;
}

.nav-link a:hover {
    color: var(--secondary-color);
    background-color: rgba(46, 125, 50, 0.1);
}

.dropdown {
    position: relative;
    margin-left: auto;
    z-index: 10;
}

.dropdown button {
    background: var(--primary-color);
    color: var(--text-light);
    border: none;
    height: 40px;
    width: 100px;
    padding: 8px 16px;
    cursor: pointer;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 500;
    display: block;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 4px var(--shadow-color);
}

.dropdown button {
    position: relative;
    z-index: 1100;
}

.dropdown button:hover {
    background: var(--secondary-color);
    transform: translateY(-1px);
    box-shadow: 0 4px 6px var(--shadow-color);
}

 .dropdown-content {
    display: none;
    position: absolute;
    border: none;
    border-radius: 4px;
    /* overlap slightly to avoid mouse gap when moving from button to menu */
    top: calc(100% - 2px);
    right: 0;
    background-color: white;
    min-width: 180px;
    box-shadow: 0 4px 12px var(--shadow-color);
    z-index: 2000;
    overflow: hidden;
}

.dropdown-content a {
    display: block;
    padding: 12px 20px;
    text-decoration: none;
    color: var(--text-dark);
    font-size: 14px;
    transition: all 0.2s ease;
}

.dropdown-content a:hover {
    background: var(--background-light);
    color: var(--primary-color);
}

.dropdown:hover .dropdown-content,
.dropdown:focus-within .dropdown-content {
    display: block;
}

/* make dropdown reachable by keyboard: show when any child has focus */
.dropdown button:focus + .dropdown-content,
.dropdown:focus-within .dropdown-content {
    display: block;
}

/* Hero Section */
.hero {
    text-align: center;
    padding: 120px 20px;
    color: var(--text-light);
    max-width: 800px;
    margin: 0 auto;
    position: relative;
}

.hero h1 {
    font-size: 56px;
    margin: 0 0 20px;
    font-weight: 700;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    letter-spacing: -0.5px;
}

.hero h2 {
    font-size: 32px;
    margin: 0 0 30px;
    font-weight: 500;
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.2);
    color: rgba(255, 255, 255, 0.9);
}

.hero p {
    font-size: 20px;
    margin: 0;
    line-height: 1.6;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
    color: rgba(255, 255, 255, 0.95);
}

/* Divider */
.divider {
    width: 100%;
    height: 4px;
    background: linear-gradient(to right, var(--primary-color), var(--secondary-color));
    margin: 0;
    opacity: 0.8;
}

/* Campaign Section */
.campaigns {
    text-align: center;
    padding: 60px 0;
    background: var(--background-light);
}

.campaign-container {
    display: flex;
    gap: 30px;
    justify-content: space-around;
    max-width: 1200px;
    margin: 40px auto;
    padding: 0 20px;
}

.campaign {
    background: white;
    border: none;
    border-radius: 8px;
    width: 320px;
    padding: 20px;
    text-align: center;
    box-shadow: 0 4px 16px var(--shadow-color);
    transition: transform 0.3s ease;
}

.campaign:hover {
    transform: translateY(-5px);
}

.campaign img {
    width: 100%;
    height: 200px;
    object-fit: cover;
    border-radius: 4px;
    margin-bottom: 15px;
}

/* Statistics */
.stats {
    display: flex;
    justify-content: space-around;
    text-align: center;
    background: linear-gradient(135deg, var(--primary-color), var(--background-dark));
    padding: 40px 20px;
    gap: 20px;
    margin: 0;
}

.stat-box {
    background: rgba(255, 255, 255, 0.1);
    padding: 25px;
    border-radius: 8px;
    width: 200px;
    backdrop-filter: blur(5px);
    transition: transform 0.3s ease;
}

.stat-box:hover {
    transform: translateY(-5px);
}

.stat-box h3 {
    font-size: 18px;
    font-weight: 600;
    color: var(--text-light);
    margin-bottom: 10px;
    text-align: center;
}

.stat-box p {
    font-size: 14px;
    color: rgba(255, 255, 255, 0.9);
    text-align: center;
    line-height: 1.6;
}
.stat-box img{
    width: 80px;;
    height: 80px;
}
/* Mission Section */
.mission {
    display: flex;
    align-items: center;
    padding: 20px;
}
.mission-text h2{
    font-size: 40px;
    margin-top: 0px;

}
.mission img {
    width: 50%;
    border-radius: 10px;
}

.mission-text {
    padding-left: 20px;
    text-align: justify;
    font-size: 20px;
}

/* Footer */
footer {
    background-color: #023606;
    padding: 20px;
    font-family: Arial, sans-serif;
}

.footer-container {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
}

.footer-left,
.footer-right {
    width: 50%;
}

.footer-left h3 {
    margin-bottom: 10px;
}

.footer-left img {
    width: 30px;
    height: 30px;
    margin-right: 10px;
    cursor: pointer;
}

.footer-left p,
.footer-right p {
    font-size: 14px;
    line-height: 1.5;
    color: #aaa9a9;
}

.footer-left a {
    text-decoration: none;
    color: #007bff;
}

.footer-left a:hover {
    text-decoration: underline;
}

    </style>
</head>
