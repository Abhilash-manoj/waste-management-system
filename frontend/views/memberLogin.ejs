<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
  <title>Member Login</title>
  <style>
    body {
      margin: 0;
      padding: 0;
      font-family: Arial, sans-serif;
      background: linear-gradient(to right, #2e7d32, #1b5e20);
      display: flex;
      flex-wrap: wrap;
      min-height: 100vh;
      justify-content: center;
      align-items: center;
      background-image: url("/images/harithamithram.png");
      background-repeat: no-repeat;
      background-size: 1000px;
      background-position: bottom left;
      background-color: #083f03;
    }

    .left-section {
      flex: 1 1 300px;
      color: white;
      padding: 40px;
      box-sizing: border-box;
    }

    .left-section h1 {
      font-size: 2.5rem;
      margin-bottom: 10px;
    }

    .left-section p {
      font-size: 1rem;
      max-width: 400px;
    }

    .container {
      flex: 1 1 400px;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 20px;
      box-sizing: border-box;
    }

    .login-card {
      position: relative;
      background: white;
      padding: 40px;
      max-width: 500px;
      width: 100%;
      border-radius: 10px;
      box-shadow: 0 5px 15px rgba(0, 0, 0, 0.2);
      text-align: center;
    }

    .login-card h2 {
      margin-bottom: 20px;
    }

    .input-group {
      margin-bottom: 15px;
      text-align: left;
    }

    .input-group label {
      display: block;
      font-size: 14px;
      margin-bottom: 5px;
    }

    .input-group input {
      width: 100%;
      padding: 10px;
      border: 1px solid #ccc;
      border-radius: 5px;
    }

    .forgot {
      display: block;
      margin-bottom: 10px;
      font-size: 14px;
      color: rgb(18, 175, 248);
      text-decoration: none;
    }

    .login-btn {
      width: 100%;
      padding: 10px;
      background: #388e3c;
      color: white;
      border: none;
      border-radius: 5px;
      font-size: 16px;
      cursor: pointer;
    }

    .login-btn:hover {
      background: #2e7d32;
    }

    .back {
      position: absolute;
      text-decoration: none;
      color: rgb(12, 12, 12);
      font-weight: bold;
      top: 20px;
      left: 20px;
      font-size: 35px;
    }

    @media screen and (max-width: 768px) {
      body {
        flex-direction: column;
        background-size: 600px;
        background-position: bottom left;
      }

      .left-section {
        text-align: center;
        padding: 20px;
      }

      .login-card {
        padding: 30px;
        max-width: 90%;
      }
    }
  </style>
</head>
<body>
  <div class="left-section">
    <h1>Haritha Keralam Mission</h1>
    <p>Progress is impossible without change, and those who cannot change their minds cannot change anything</p>
  </div>
  <div class="container">
    <form class="login-card" id="loginForm" action="/member/memberlogin" method="POST">
      <a href="/home" class="back">&lArr;</a>
      <h1>Log In</h1>
      <h2>Member</h2>

      <div class="input-group">
        <label for="housenumber">House Number</label>
        <input type="text" name="housenumber" id="housenumber" placeholder="Enter HouseNumber" required />
      </div>

      <div class="input-group">
        <label for="wardnumber">Ward Number</label>
        <input type="text" name="wardnumber" id="wardnumber" placeholder="Enter WardNumber" required />
      </div>

      <div class="input-group">
        <label for="pass">Password</label>
        <input type="password" name="pass" id="pass" placeholder="Enter Password" required />
      </div>

      <a class="forgot" href="/memberforgotpassword">Forgot Password</a>
      <button type="submit" class="login-btn">Submit</button>
    </form>
  </div>

  <script>
    class LoginValidator {
      constructor(formId) {
        this.form = document.getElementById(formId);
        this.houseInput = document.getElementById('housenumber');
        this.wardInput = document.getElementById('wardnumber');
        this.passInput = document.getElementById('pass');
        this.attachEvents();
      }

      attachEvents() {
        this.form.addEventListener('submit', (e) => this.validateForm(e));
      }

      validateForm(e) {
        const house = this.houseInput.value.trim();
        const ward = this.wardInput.value.trim();
        const pass = this.passInput.value.trim();
        let errors = [];

        if (!house.match(/^[A-Za-z0-9\-\/]+$/)) {
          errors.push("House Number contains invalid characters.");
        }

        if (!ward.match(/^\d+$/)) {
          errors.push("Ward Number must be numeric.");
        }

        const hasLower = /[a-z]/.test(pass);
        const hasUpper = /[A-Z]/.test(pass);
        const hasSpecial = /[!@#$%^&*(),.?\":{}|<>]/.test(pass);
        const isLongEnough = pass.length >= 6;

        if (!isLongEnough || !hasLower || !hasUpper || !hasSpecial) {
          errors.push("Password must be at least 6 characters and include a lowercase letter, uppercase letter, and special character.");
        }

        if (errors.length > 0) {
          e.preventDefault();
          alert(errors.join("\\n"));
        }
      }
    }

    document.addEventListener('DOMContentLoaded', () => {
      new LoginValidator('loginForm');
    });
  </script>
</body>
</html>