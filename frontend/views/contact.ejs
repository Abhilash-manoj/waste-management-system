<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Haritha Kerala Mission</title>
    <style>
        :root {
    --primary-color: #1b5e20;
    --secondary-color: #2e7d32;
    --accent-color: #43a047;
    --text-light: #ffffff;
    --text-dark: #333333;
    --background-light: #f5f5f5;
    --background-dark: #004d40;
    --shadow-color: rgba(0, 0, 0, 0.1);
}

        body {
    margin: 0;
    font-family: 'Segoe UI', Arial, sans-serif;
    background: var(--background-light);
    color: var(--text-dark);
    line-height: 1.6;
}

.container {
    background-image: linear-gradient(rgba(0, 0, 0, 0.5), rgba(0, 0, 0, 0.5)), url(../components/main.jpeg);
    background-repeat: no-repeat;
    background-position: center;
    background-size: cover;
    width: 100%;
    height: 600px;
    margin: 0;
    padding: 0;
    max-width: 100%;
    overflow: hidden;
    position: relative;
}

/* Navigation Bar */
.nav-bar {
    display: flex;
    justify-content: flex-end;
    align-items: center;
    padding: 15px 40px;
    width: 100%;
    box-sizing: border-box;
    position: relative;
    background: rgba(255, 255, 255, 0.95);
    box-shadow: 0 2px 4px var(--shadow-color);
}

.nav-link {
    position: absolute;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 40px;
    justify-content: center;
    align-items: center;
}

.nav-link a {
    text-decoration: none;
    color: var(--primary-color);
    font-size: 16px;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    transition: all 0.3s ease;
    padding: 8px 16px;
    border-radius: 4px;
}

.nav-link a:hover {
    color: var(--secondary-color);
    background-color: rgba(46, 125, 50, 0.1);
}

.dropdown {
    position: relative;
    margin-left: auto;
    z-index: 10;
}

.dropdown button {
    background: var(--primary-color);
    color: var(--text-light);
    border: none;
    height: 40px;
    width: 100px;
    padding: 8px 16px;
    cursor: pointer;
    border-radius: 4px;
    font-size: 15px;
    font-weight: 500;
    display: block;
    transition: all 0.3s ease;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    box-shadow: 0 2px 4px var(--shadow-color);
}

.dropdown button {
    position: relative;
    z-index: 1100;
}

.dropdown button:hover {
    background: var(--secondary-color);
    transform: translateY(-1px);
    box-shadow: 0 4px 6px var(--shadow-color);
}

.dropdown-content {
    display: none;
    position: absolute;
    border: none;
    border-radius: 4px;
    top: calc(100% - 2px);
    right: 0;
    background-color: white;
    min-width: 180px;
    box-shadow: 0 4px 12px var(--shadow-color);
    z-index: 2000;
    overflow: hidden;
}

.dropdown-content a {
    display: block;
    padding: 12px 20px;
    text-decoration: none;
    color: var(--text-dark);
    font-size: 14px;
    transition: all 0.2s ease;
}

.dropdown-content a:hover {
    background: var(--background-light);
    color: var(--primary-color);
}

.dropdown:hover .dropdown-content,
.dropdown:focus-within .dropdown-content {
    display: block;
}

/* keyboard accessibility */
.dropdown button:focus + .dropdown-content,
.dropdown:focus-within .dropdown-content {
    display: block;
}

/* keyboard accessibility */
.dropdown button:focus + .dropdown-content,
.dropdown:focus-within .dropdown-content {
    display: block;
}

/* Hero Section */
.hero {
    text-align: center;
    padding: 120px 20px;
    color: var(--text-light);
    max-width: 800px;
    margin: 0 auto;
    position: relative;
}

.hero h1 {
    font-size: 56px;
    margin: 0 0 20px;
    font-weight: 700;
    text-shadow: 2px 2px 4px rgba(0, 0, 0, 0.3);
    letter-spacing: -0.5px;
    color: var(--text-light);
}

.hero h2 {
    font-size: 32px;
    margin: 0 0 30px;
    font-weight: 500;
    text-shadow: 1px 1px 3px rgba(0, 0, 0, 0.2);
    color: rgba(255, 255, 255, 0.9);
}

.hero p {
    font-size: 20px;
    margin: 0;
    line-height: 1.6;
    text-shadow: 1px 1px 2px rgba(0, 0, 0, 0.2);
    color: rgba(255, 255, 255, 0.95);
}

.hero h1, 
.hero h2, 
.hero p {
    line-height: 1.2; 
}

/* Divider */
.divider {
    width: 100%;
    height: 10px;
    background: #06610c;
    margin: 0px;
}
.contact {
    display: flex;
    flex-direction: column;
    gap: 20px;
    padding: 10px;
    width: 100%;
    margin: auto;
    border-radius: 10px;
}

/* Location Info (Google Map + Address) */
.main-info {
    display: flex;
    gap: 20px;
}

.map {
    flex:2;
    width: 650px;
    height: 550px;
    margin: auto;
}

.contact h2 {
    color: var(--text-dark);
    text-align: left;
    font-weight: 600;
    margin-bottom: 20px;
}

.location-info{
    flex: 1;
    width: 350px;
    height: auto;
    border-radius: 10px;
}

.location-info h2 {
    font-size: 20px;
    color: var(--text-dark);
    margin-top: 5px;
    text-align: left;
    font-weight: 600;
}

.location-info p {
    font-size: 16px;
    color: var(--text-dark);
    line-height: 1.6;
}

/* Contact Info (Phone & Email) */
.contact-info {
    flex: 1;
    border-radius: 10px;
    width: 350px;
    height: auto;
}

.contact-info h3 {
    font-size: 18px;
    color: var(--text-dark);
    margin-left: 10px;
    text-align: left;
    font-weight: 500;
}

.contact-info a {
    text-decoration: none;
    color: turquoise;
    font-size: 18px;
}

.contact-info a:hover {
    text-decoration: underline;
    color: #0864ee;
}

/* Footer */
footer {
    background-color: #023606;
    padding: 20px;
    width: 100%;
    font-family: Arial, sans-serif;
}

.footer-container {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    gap: 20px;
}

.footer-left,
.footer-right {
    width: 50%;
}

.footer-left h3 {
    margin-bottom: 10px;
}

.footer-left img {
    width: 30px;
    height: 30px;
    margin-right: 10px;
    cursor: pointer;
}

.footer-left p,
.footer-right p {
    font-size: 14px;
    line-height: 1.5;
    color: #aaa9a9;
}

.footer-left a {
    text-decoration: none;
    color: #007bff;
}

.footer-left a:hover {
    text-decoration: underline;
}

    /* Footer Styles */
    footer {
        background: linear-gradient(135deg, var(--primary-color), var(--background-dark));
        color: var(--text-light);
        padding: 60px 0 40px;
        margin-top: 40px;
        box-shadow: 0 -4px 12px var(--shadow-color);
    }

    .footer-container {
        display: flex;
        max-width: 1200px;
        margin: 0 auto;
        padding: 0 40px;
        gap: 60px;
    }

    .footer-left,
    .footer-right {
        width: 50%;
    }

    .footer-left h3 {
        font-size: 20px;
        margin-bottom: 20px;
        color: white;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
    }

    .footer-left img {
        width: 32px;
        height: 32px;
        margin-right: 15px;
        cursor: pointer;
        transition: transform 0.3s ease;
        opacity: 0.9;
        background-color: rgba(255, 255, 255, 0.1);
        padding: 6px;
        border-radius: 50%;
    }

    .footer-left img:hover {
        transform: translateY(-3px);
        opacity: 1;
        background-color: rgba(255, 255, 255, 0.2);
    }

    .footer-left p {
        font-size: 15px;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.9);
        margin: 8px 0;
    }

    .footer-right p {
        font-size: 15px;
        line-height: 1.8;
        color: rgba(255, 255, 255, 0.9);
    }

    .footer-left a {
        text-decoration: none;
        color: #81C784;
        font-weight: 500;
        transition: color 0.3s ease;
    }

    .footer-left a:hover {
        color: #A5D6A7;
        text-decoration: underline;
    }

    /* Contact Form Styles */
    .contact-section {
        max-width: 800px;
        margin: 60px auto;
        padding: 0 20px;
    }

    .contact-form {
        background: white;
        padding: 40px;
        border-radius: 8px;
        box-shadow: 0 4px 12px var(--shadow-color);
    }

    .contact-form h2 {
        color: var(--text-dark);
        margin-bottom: 30px;
        font-size: 32px;
        text-align: center;
        font-weight: 600;
    }

    .form-group {
        margin-bottom: 20px;
    }

    .form-group label {
        display: block;
        margin-bottom: 8px;
        color: var(--text-dark);
        font-weight: 500;
    }

    .form-group input,
    .form-group textarea {
        width: 100%;
        padding: 12px;
        border: 1px solid #ddd;
        border-radius: 4px;
        font-size: 16px;
        transition: border-color 0.3s ease;
    }

    .form-group input:focus,
    .form-group textarea:focus {
        border-color: var(--primary-color);
        outline: none;
        box-shadow: 0 0 0 2px rgba(27, 94, 32, 0.1);
    }

    .form-group textarea {
        min-height: 150px;
        resize: vertical;
    }

    .submit-btn {
        background: var(--primary-color);
        color: white;
        padding: 12px 24px;
        border: none;
        border-radius: 4px;
        font-size: 16px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
        display: block;
        width: 100%;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .submit-btn:hover {
        background: var(--secondary-color);
        transform: translateY(-1px);
        box-shadow: 0 4px 8px var(--shadow-color);
    }

    </style>
</head>
