<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Member Dashboard</title>
  <style>
    body {
      margin: 0;
      font-family: Arial, sans-serif;
      background-color: #D6FFC3;
    }
    .sidebar {
      width: 250px;
      background-color: #04640A;
      color: white;
      position: fixed;
      height: 100%;
    }
    .sidebar h2 {
      text-align: center;
      margin-bottom: 20px;
    }
    .sidebar a {
      text-decoration: none;
      color: white;
      display: block;
      padding: 10px 15px;
      border-radius: 5px;
      margin-bottom: 10px;
    }
    .sidebar a:hover {
      background-color: rgb(2, 65, 6);
    }
    .main {
      margin-left: 250px;
      padding: 20px;
    }
    .header {
      text-align: center;
      margin-bottom: 20px;
      font-size: 1.5em;
      color: rgb(3, 44, 5);
    }
    .admin-profile {
      display: flex;
      flex-direction: column;
      align-items: center;
    }
    .admin-profile-pic {
      width: 100px;
      height: 100px;
      border-radius: 50%;
      margin-bottom: 10px;
      cursor: pointer;
    }
    .admin-profile-pic:hover {
      width: 110px;
      height: 110px;
      transition: all 0.2s ease;
    }
    .thin-green-line {
      width: 100%;
      height: 5px;
      background-color: #149703;
      margin: 0px 0;
    }
    .accept {
      color: white;
      background-color: green;
      border-radius: 10px;
      border: solid green;
      width: 80px;
      height: 40px;
      cursor: pointer;
    }
    .reject {
      color: white;
      background-color: red;
      border-radius: 10px;
      border: solid red;
      width: 80px;
      height: 40px;
      cursor: pointer;
    }
  </style>
</head>
<body>
  <div class="sidebar">
    <div class="admin-profile">
      <h2>Dashboard</h2>
      <img src="<%= session.member.profilePicture || 'https://placehold.co/80x80/4CAF50/FFFFFF?text=M' %>" class="admin-profile-pic" alt="Profile Picture" />
      <h3><%= session.member.name %></h3>
      <h5><%= session.member.houseName %></h5>
      <a href="/member/memberEditProfile">Edit Profile</a>
    </div>
    <div class="thin-green-line"></div>
    <div class="main-menu">
      <a href="/member/memberdashboard">Home</a>
    </div>
    <div class="thin-green-line"></div>
    <div class="sub-menu">
      <a onclick="showForm('submitrequest')">Submit Request</a>
      <a onclick="showForm('submitfeedback')">Submit Feedback</a>
      <a onclick="loadWasteRequests(); showForm('Requests')">View Requests</a>
      <a onclick="loadFeedback(); showForm('viewfeedback')">View Feedback</a>
      <a href="/home">Log Out</a>
    </div>
  </div>

  <div class="main">
    <!-- Submit Request Form -->
    <div id="submit-request-form" style="display:none; margin-top:20px;">
      <div class="header">
        <h2>Submit Request</h2>
      </div>
      <form id="requestForm">
        <input type="hidden" name="memberId" value="<%= session.member.id %>" />

        <label>House Number:</label><br />
        <input type="text" name="houseNumber" value="<%= session.member.houseNumber %>" readonly /><br /><br />

        <label>Ward Number:</label><br />
        <input type="text" name="wardNumber" value="<%= session.member.wardNumber %>" readonly /><br /><br />

        <label>Waste Type:</label><br />
        <select name="wasteType" required>
          <option value="">--Select--</option>
          <option value="Organic">Organic Waste</option>
          <option value="Plastic">Plastic Waste</option>
          <option value="Metal">Metal Waste</option>
          <option value="Electronic">Electronic Waste</option>
        </select><br /><br />

        <label>Preferred Date Start:</label><br />
        <input type="date" name="preferredDateStart" /><br /><br />

        <label>Preferred Date End:</label><br />
        <input type="date" name="preferredDateEnd" /><br /><br />

        <button type="submit" class="accept">Submit</button>
      </form>
    </div>

    <!-- Submit Feedback Form -->
    <div id="submit-feedback-form" style="display:none; margin-top:20px;">
      <div class="header">
        <h2>Submit Feedback</h2>
      </div>
      <form id="feedbackForm">
        <input type="hidden" name="memberId" value="<%= session.member.id %>" />

        <label>House Number:</label><br />
        <input type="text" name="houseNumber" value="<%= session.member.houseNumber %>" readonly /><br /><br />

        <label>Ward Number:</label><br />
        <input type="text" name="wardNumber" value="<%= session.member.wardNumber %>" readonly /><br /><br />

        <label>Date:</label><br />
        <input type="date" name="datesubmitted" required /><br /><br />

        <label>Comment:</label><br />
        <textarea name="comment" required></textarea><br /><br />

        <button type="submit" class="accept">Submit</button>
      </form>
    </div>

    <!-- View Feedback -->
    <div id="view-feedback-form" style="display:none; margin-top:20px;">
      <div class="header"><h2>View Feedback</h2></div>
      <div id="view-feedback"></div>
    </div>

    <!-- View Requests -->
    <div id="view-requests-form" style="display:none; margin-top:20px;">
      <div class="header"><h2>View Requests</h2></div>
      <div id="view-requests"></div>
    </div>
  </div>

  <script>
    function showForm(type) {
      document.getElementById("submit-request-form").style.display = type === "submitrequest" ? "block" : "none";
      document.getElementById("submit-feedback-form").style.display = type === "submitfeedback" ? "block" : "none";
      document.getElementById("view-feedback-form").style.display = type === "viewfeedback" ? "block" : "none";
      document.getElementById("view-requests-form").style.display = type === "Requests" ? "block" : "none";
    }
// Submit Request using JS
document.getElementById("requestForm").addEventListener("submit", async (e) => {
  e.preventDefault();
  const formData = new FormData(e.target);
  const data = Object.fromEntries(formData.entries());

  try {
    const res = await fetch("/member/submitrequest", {
      method: "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(data),
    });

    // Try to parse the response JSON
    const result = await res.json();

    if (res.ok && result.success) {
      alert("✅ Request submitted successfully!");
    } else {
      
      const msg = result.errors
        ? result.errors.join("\n") 
        : result.message || "Unknown error";
      alert(`❌ Failed: ${msg}`);
    }
  } catch (err) {
    alert("❌ Error submitting request: " + err.message);
    console.error("Submit request error:", err);
  }
});

    // Submit Feedback using JS
    document.getElementById("feedbackForm").addEventListener("submit", async (e) => {
      e.preventDefault();
      const formData = new FormData(e.target);
      const data = Object.fromEntries(formData.entries());

      try {
        const res = await fetch("/member/submitfeedback", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(data),
        });
        const result = await res.json();
        if (res.ok) alert("✅ Feedback submitted successfully!");
        else alert(`❌ Failed: ${result.message || "Unknown error"}`);
      } catch (err) {
        alert("❌ Error submitting feedback: " + err.message);
      }
    });

    // Load Feedback
    async function loadFeedback() {
      const container = document.getElementById("view-feedback");
      container.innerHTML = "⏳ Loading feedback...";
      try {
        const res = await fetch("/member/viewfeedback");
        const json = await res.json();
        const feedback = json.data || [];
        if (!feedback.length) return (container.innerHTML = "No feedback found.");
        container.innerHTML = feedback
          .map(
            (f) => `
          <div style="background:white;border:1px solid #ccc;padding:10px;border-radius:8px;margin-bottom:10px;">
            <h3 style="color:#04640A;">${f.MemberName}</h3>
            <p><strong>Waste Type:</strong> ${f.WasteType}</p>
            <p><strong>Comment:</strong> ${f.Comments}</p>
            <p><strong>Date:</strong> ${f.DateSubmitted}</p>
          </div>`
          )
          .join("");
      } catch (err) {
        alert("❌ Error loading feedback: " + err.message);
      }
    }

    // Load Requests
    async function loadWasteRequests() {
      const container = document.getElementById("view-requests");
      container.innerHTML = "⏳ Loading requests...";
      try {
        const res = await fetch("/member/viewrequests");
        const json = await res.json();
        const requests = json.data || [];
        if (!requests.length) return (container.innerHTML = "No requests found.");
        container.innerHTML = requests
          .map(
            (r) => `
          <div style="background:white;border:1px solid #ccc;padding:10px;border-radius:8px;margin-bottom:10px;">
            <h3 style="color:#04640A;">Request #${r.Request_ID}</h3>
            <p><strong>Member:</strong> ${r.MemberName}</p>
            <p><strong>Waste Type:</strong> ${r.WasteType}</p>
            <p><strong>Status:</strong> ${r.Status}</p>
          </div>`
          )
          .join("");
      } catch (err) {
        alert("❌ Error loading requests: " + err.message);
      }
    }
  </script>
</body>
</html>
