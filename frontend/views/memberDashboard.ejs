<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Member Dashboard</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600;700&display=swap"
    rel="stylesheet"
  />
  <style>
    /* --- 1. Base & Reset Styles --- */
    :root {
      --green-dark: #1a8754;
      --green-light-bg: #f0fdf4;
      --green-text: #15803d;
      --gray-bg: #f9fafb; /* Main background */
      --gray-border: #e5e7eb;
      --gray-text: #6b7280;
      --gray-dark-text: #1f2937;
      --white: #ffffff;
      --shadow-sm: 0 1px 2px rgba(0, 0, 0, 0.05);
      --radius-md: 8px;
      --radius-lg: 12px;
    }

    * {
      box-sizing: border-box;
      margin: 0;
      padding: 0;
    }

    body {
      margin: 0;
      font-family: "Poppins", Arial, sans-serif;
      background-color: var(--gray-bg);
      color: var(--gray-dark-text);
      display: flex; /* This creates the sidebar/main layout */
    }

    /* --- 2. Sidebar --- */
    .sidebar {
      width: 260px; /* Changed from 250px */
      background-color: var(--white);
      color: var(--gray-dark-text);
      position: fixed;
      height: 100%;
      border-right: 1px solid var(--gray-border);
      padding: 24px;
      display: flex;
      flex-direction: column;
    }

    .sidebar h2 {
      text-align: left;
      margin-bottom: 8px;
      font-size: 1.5em;
      font-weight: 700;
      color: var(--green-dark);
      padding-left: 10px; /* Aligns with profile */
    }

    .admin-profile {
      text-align: center;
      padding-bottom: 24px;
      border-bottom: 1px solid var(--gray-border);
    }
    .admin-profile-pic {
      width: 80px;
      height: 80px;
      border-radius: 50%;
      margin-bottom: 12px;
      object-fit: cover;
      border: 2px solid var(--gray-border);
      cursor: default;
    }
    .admin-profile h3 {
      font-size: 1.15em;
      font-weight: 600;
      color: var(--gray-dark-text);
      margin-bottom: 2px;
    }
    .admin-profile h5 {
      font-size: 0.9em;
      font-weight: 400;
      color: var(--gray-text);
      margin-bottom: 12px;
    }
    .admin-profile a {
      font-size: 0.9em;
      font-weight: 500;
      color: var(--green-dark);
      text-decoration: none;
    }
    .admin-profile a:hover {
      text-decoration: underline;
    }

    .main-menu,
    .sub-menu {
      margin-top: 16px;
    }

    .sidebar a {
      text-decoration: none;
      color: var(--gray-text);
      display: flex;
      align-items: center;
      gap: 12px;
      padding: 12px 16px;
      border-radius: var(--radius-md);
      margin-bottom: 8px;
      font-weight: 500;
      transition: all 0.2s ease;
    }
    .sidebar a:hover {
      background-color: var(--gray-bg);
      color: var(--gray-dark-text);
    }
    .sidebar a.active {
      background-color: var(--green-light-bg);
      color: var(--green-text);
      font-weight: 600;
    }

    .thin-green-line {
      display: none;
    }

    /* --- 3. Main Content --- */
    .main {
      margin-left: 260px;
      padding: 32px;
      width: calc(100% - 260px);
    }

    .main-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 32px;
    }
    .main-header h1 {
      font-size: 2.25em;
      font-weight: 700;
    }
    .main-header p {
      font-size: 1.1em;
      color: var(--gray-text);
    }

    /* --- CHANGE --- 
      Removed card styling from the main containers.
      They are now just wrappers.
    */
    #submit-request-form,
    #submit-feedback-form,
    #view-feedback-form,
    #view-requests-form {
      margin-top: 20px;
    }
    
    .header {
      text-align: left;
      margin-bottom: 24px;
      font-size: 1.2em;
      color: var(--gray-dark-text);
    }
    .header h2 {
      font-size: 1.5em;
    }

    /* --- 4. Form Styles --- */
    
    /* --- NEW --- 
      Added card styling to the *actual forms*
      and gave them a max-width.
    */
    #requestForm,
    #feedbackForm {
      background-color: var(--white);
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      border: 1px solid var(--gray-border);
      padding: 24px;
      max-width: 700px; /* This makes the card smaller */
    }

    /* --- NEW --- Form Group helper */
    .form-group {
      margin-bottom: 16px;
    }
    
    .form-group label {
      font-weight: 500;
      margin-bottom: 8px;
      font-size: 0.9em;
      display: block; /* Make label stack on top */
    }
    
    /* Apply styles to all inputs within a form group */
    .form-group input[type="text"],
    .form-group input[type="date"],
    .form-group select,
    .form-group textarea {
      width: 100%;
      padding: 12px;
      border: 1px solid var(--gray-border);
      border-radius: var(--radius-md);
      font-family: "Poppins", Arial, sans-serif;
      font-size: 1em;
    }
    
    .form-group input[readonly] {
      background-color: var(--gray-bg);
    }

    /* --- 5. Button Styles --- */
    .accept {
      font-family: "Poppins", Arial, sans-serif;
      font-size: 1em;
      font-weight: 600;
      padding: 12px 24px;
      border-radius: var(--radius-md);
      border: none;
      cursor: pointer;
      transition: all 0.2s ease;
      background-color: var(--green-dark);
      color: var(--white);
      width: auto;
      height: auto;
      margin-top: 10px; /* Add some space above the button */
    }
    .accept:hover {
      background-color: #14532d;
    }
    .reject {
      font-family: "Poppins", Arial, sans-serif;
      font-size: 1em;
      font-weight: 600;
      padding: 12px 24px;
      border-radius: var(--radius-md);
      border: none;
      cursor: pointer;
      transition: all 0.2s ease;
      background-color: #dc2626;
      color: var(--white);
      width: auto;
      height: auto;
    }

    /* --- 6. Request Card Styles --- */
    #view-requests,
    #view-feedback {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
      gap: 20px;
    }

    .request-card {
      background: var(--white);
      border: 1px solid var(--gray-border);
      padding: 16px; /* Made cards smaller */
      border-radius: var(--radius-lg);
      box-shadow: var(--shadow-sm);
      display: flex;
      flex-direction: column;
      gap: 6px;
    }
    .request-card h3 {
      font-size: 1.1em;
      margin: 0;
      color: var(--green-text);
    }
    .request-card p {
      font-size: 0.9em;
      color: var(--gray-text);
      margin: 0;
    }
    .request-card p strong {
      color: var(--gray-dark-text);
      font-weight: 500;
    }
  </style>
</head>
<body>
  <div class="sidebar">
    <div class="admin-profile">
      <h2>Dashboard</h2>
      <img
        src="<%= session.member.profilePicture || 'https://placehold.co/80x80/4CAF50/FFFFFF?text=M' %>"
        class="admin-profile-pic"
        alt="Profile Picture"
      />
      <h3><%= session.member.name %></h3>
      <h5><%= session.member.houseName %></h5>
      <a href="/member/memberEditProfile">Edit Profile</a>
    </div>
    <div class="thin-green-line"></div>
    <div class="main-menu">
      <a onclick="loadWasteRequests(); showForm('Requests')">Home</a>
    </div>
    <div class="thin-green-line"></div>
    <div class="sub-menu">
      <a onclick="showForm('submitrequest')">Submit Request</a>
      <a onclick="showForm('submitfeedback')">Submit Feedback</a>
      <a onclick="loadFeedback(); showForm('viewfeedback')">View Feedback</a>
      <a href="/home">Log Out</a>
    </div>
  </div>

  <div class="main">
    <header class="main-header">
      <div>
        <h1>Hello, <%= session.member.name %>!</h1>
        <p>Welcome back, let's manage your waste disposal requests.</p>
      </div>
    </header>

    <div id="submit-request-form" style="display: none; margin-top: 20px">
      <div class="header">
        <h2>Submit Request</h2>
      </div>
      <form id="requestForm">
        <input type="hidden" name="memberId" value="<%= session.member.id %>" />

        <div class="form-group">
          <label>House Number:</label>
          <input
            type="text"
            name="houseNumber"
            value="<%= session.member.houseNumber %>"
            readonly
          />
        </div>
        
        <div class="form-group">
          <label>Ward Number:</label>
          <input
            type="text"
            name="wardNumber"
            value="<%= session.member.wardNumber %>"
            readonly
          />
        </div>
        
        <div class="form-group">
          <label>Waste Type:</label>
          <select name="wasteType" required>
            <option value="">--Select--</option>
            <option value="Organic">Organic Waste</option>
            <option value="Plastic">Plastic Waste</option>
            <option value="Metal">Metal Waste</option>
            <option value="Electronic">Electronic Waste</option>
          </select>
        </div>

        <div class="form-group">
          <label>Preferred Date Start:</label>
          <input type="date" name="preferredDateStart" />
        </div>
        
        <div class="form-group">
          <label>Preferred Date End:</label>
          <input type="date" name="preferredDateEnd" />
        </div>
        
        <button type="submit" class="accept">Submit</button>
      </form>
    </div>

    <div id="submit-feedback-form" style="display: none; margin-top: 20px">
      <div class="header">
        <h2>Submit Feedback</h2>
      </div>
      <form id="feedbackForm">
        <input type="hidden" name="memberId" value="<%= session.member.id %>" />

        <div class="form-group">
          <label>House Number:</label>
          <input
            type="text"
            name="houseNumber"
            value="<%= session.member.houseNumber %>"
            readonly
          />
        </div>
        
        <div class="form-group">
          <label>Ward Number:</label>
          <input
            type="text"
            name="wardNumber"
            value="<%= session.member.wardNumber %>"
            readonly
          />
        </div>
        

        <div class="form-group">
          <label>Comment:</label>
          <textarea name="comment" required></textarea>
        </div>

        <button type="submit" class="accept">Submit</button>
      </form>
    </div>

    <div id="view-feedback-form" style="display: none; margin-top: 20px">
      <div class="header"><h2>View Feedback</h2></div>
      <div id="view-feedback"></div>
    </div>

    <div id="view-requests-form" style="display: none; margin-top: 20px">
      <div class="header"><h2>View Requests</h2></div>
      <div id="view-requests"></div>
    </div>
  </div>

  <script>
    // This is your original function, 100% unchanged.
    function showForm(type) {
      document.getElementById("submit-request-form").style.display =
        type === "submitrequest" ? "block" : "none";
      document.getElementById("submit-feedback-form").style.display =
        type === "submitfeedback" ? "block" : "none";
      document.getElementById("view-feedback-form").style.display =
        type === "viewfeedback" ? "block" : "none";
      document.getElementById("view-requests-form").style.display =
        type === "Requests" ? "block" : "none";
    }
    // This is your original function, 100% unchanged.
    document
      .getElementById("requestForm")
      .addEventListener("submit", async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target);
        const data = Object.fromEntries(formData.entries());

        try {
          const res = await fetch("/member/submitrequest", {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify(data),
          });

          // Try to parse the response JSON
          const result = await res.json();

          if (res.ok && result.success) {
            alert("✅ Request submitted successfully!");
          } else {
            const msg = result.errors
              ? result.errors.join("\n")
              : result.message || "Unknown error";
            alert(`❌ Failed: ${msg}`);
          }
        } catch (err) {
          alert("❌ Error submitting request: " + err.message);
          console.error("Submit request error:", err);
        }
      });

   document.getElementById("feedbackForm").addEventListener("submit", function (e) {
    e.preventDefault();

    const formData = new FormData(this);
    const currentDate = new Date().toISOString().split("T")[0]; // YYYY-MM-DD format
    formData.append("datesubmitted", currentDate);

    fetch("/member/submitfeedback", {
      method: "POST",
      body: new URLSearchParams(formData),
    })
      .then((res) => res.json())
      .then((data) => {
        if (data.success) {
          alert("✅ Feedback submitted successfully!");
          this.reset();
        } else {
          alert("❌ " + (data.message || "Failed to submit feedback."));
        }
      })
      .catch((err) => {
        console.error("Error submitting feedback:", err);
        alert("❌ Error submitting feedback. Please try again.");
      });
  });

    // --- JAVASCRIPT IS UNCHANGED ---
    // Your .map() functions already work perfectly with the grid.
    async function loadFeedback() {
      const container = document.getElementById("view-feedback");
      container.innerHTML = "⏳ Loading feedback...";
      try {
        const res = await fetch("/member/viewfeedback");
        const json = await res.json();
        const feedback = json.data || [];
        if (!feedback.length)
          return (container.innerHTML = "<p>No feedback found.</p>");
        
        // --- CHANGE --- Clear container *after* fetch
        container.innerHTML = "";
        
        feedback.forEach((f) => {
            const card = document.createElement("div");
            card.className = "request-card";
            card.innerHTML = `
              <h3>${f.MemberName}</h3>
              <p><strong>Comment:</strong> ${f.Comments}</p>
              <p><strong>Date:</strong> ${f.DateSubmitted}</p>
            `;
            container.appendChild(card);
        });
      } catch (err) {
        alert("❌ Error loading feedback: " + err.message);
      }
    }

    async function loadWasteRequests() {
      const container = document.getElementById("view-requests");
      container.innerHTML = "⏳ Loading requests...";
      try {
        const res = await fetch("/member/viewrequests");
        const json = await res.json();
        const requests = json.data || [];
        if (!requests.length)
          return (container.innerHTML = "<p>No requests found.</p>");

        // --- CHANGE --- Clear container *after* fetch
        container.innerHTML = "";

        requests.forEach((r) => {
            const card = document.createElement("div");
            card.className = "request-card";
            card.innerHTML = `
              <h3>Request #${r.Request_ID}</h3>
            <p><strong>Member:</strong> ${r.MemberName || "Unknown"}</p>
            <p><strong>House:</strong> ${r.HouseNumber || "N/A"} | <strong>Ward:</strong> ${r.WardNumber || "N/A"}</p>
            <p><strong>Waste Type:</strong> ${r.WasteType}</p>
            <p><strong>Status:</strong> ${r.Status}</p>
            <p><strong>Assigned Worker:</strong> ${r.WorkerName ? `${r.WorkerName} (ID: ${r.Worker_ID})` : "Not assigned"}</p>`;
            container.appendChild(card);
        });
      } catch (err) {
        alert("❌ Error loading requests: " + err.message);
      }
    }
  </script>
</body>
</html>